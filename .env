# CyberDashboard — Environment Variables
# ----------------------------------------

# ── NVD (NIST National Vulnerability Database) ──────────────────────────────
# Clé optionnelle — sans clé : 5 req/30s, avec clé : 50 req/30s
# Obtenir une clé gratuite : https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── PhishTank ────────────────────────────────────────────────────────────────
# Clé optionnelle — sans clé : accès limité
# Register at: https://www.phishtank.com/api_register.php
PHISHTANK_API_KEY=

# ── CISA KEV (Known Exploited Vulnerabilities) ───────────────────────────────
# GRATUIT — Aucune clé requise
# Source officielle US des CVE activement exploitées en conditions réelles
# Mise à jour quotidienne : https://www.cisa.gov/known-exploited-vulnerabilities-catalog
# (aucune variable à configurer)

# ── URLhaus (abuse.ch) ───────────────────────────────────────────────────────
# GRATUIT — Aucune clé requise
# URLs malveillantes actives, mise à jour temps réel
# https://urlhaus.abuse.ch/
# (aucune variable à configurer)

# ── MalwareBazaar (abuse.ch) ─────────────────────────────────────────────────
# GRATUIT — Aucune clé requise
# Samples malware récents avec hashes SHA256
# https://bazaar.abuse.ch/
# (aucune variable à configurer)

# ── Paramètres généraux ──────────────────────────────────────────────────────
# Score CVSS minimum pour importer une vulnérabilité (défaut : 7.0)
CVSS_MIN=7.0

# MISP/Botvrij feed URL (default is public Botvrij domain IoC list)
MISP_BASE_URL=https://www.botvrij.eu/data/ioclist.domain.raw
